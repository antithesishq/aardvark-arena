#!/usr/bin/env bash
set -euo pipefail

# Launch a single well-behaved player that plays a random number of sessions
# (1-20) then exits. Antithesis Test Composer re-invokes parallel_driver_
# commands after exit, creating a continuous stream of fresh players.

NUM_SESSIONS=$(( (RANDOM % 20) + 1 ))

exec player \
    -matchmaker=http://aardvark-arena-matchmaker:8080 \
    -num-sessions="$NUM_SESSIONS" \
    -poll-interval=500ms
